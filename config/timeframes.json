{
  "_description": "Multi-Timeframe configuration for V10",
  "_version": "10.0.0",
  "_last_updated": "2026-03-20",

  "timeframes": {
    "4h": {
      "name": "4-Hour",
      "description": "Short-term momentum, entry/exit timing",
      "binance_interval": "4h",
      "candles_per_day": 6,

      "weight": 0.30,
      "_comment_weight": "30% weight - Short-term signals for timing",

      "lookahead_candles": 42,
      "_comment_lookahead": "42 candles = 7 days (6 candles/day × 7)",

      "feature_importance": {
        "momentum": 0.40,
        "volatility": 0.30,
        "volume": 0.20,
        "pattern": 0.10,
        "_comment": "4h focuses on momentum and volatility"
      },

      "use_for": [
        "entry_timing",
        "exit_signals",
        "stop_loss_placement",
        "short_term_reversals"
      ],

      "min_data_points": 500,
      "_comment_data": "Minimum 500 candles (~83 days) for training"
    },

    "1d": {
      "name": "1-Day (Daily)",
      "description": "Medium-term trends, swing trading (V9's timeframe)",
      "binance_interval": "1d",
      "candles_per_day": 1,

      "weight": 0.50,
      "_comment_weight": "50% weight - PRIMARY timeframe (V9 baseline)",

      "lookahead_candles": 7,
      "_comment_lookahead": "7 candles = 7 days (V9 standard)",

      "feature_importance": {
        "trend": 0.40,
        "momentum": 0.25,
        "btc_influence": 0.20,
        "volume": 0.15,
        "_comment": "1d focuses on trend and BTC correlation"
      },

      "use_for": [
        "primary_signals",
        "trend_confirmation",
        "btc_influence",
        "medium_term_targets"
      ],

      "min_data_points": 365,
      "_comment_data": "Minimum 365 candles (1 year) for training"
    },

    "1w": {
      "name": "1-Week (Weekly)",
      "description": "Long-term trends, market regime detection",
      "binance_interval": "1w",
      "candles_per_day": 0.142857,

      "weight": 0.20,
      "_comment_weight": "20% weight - Long-term confirmation",

      "lookahead_candles": 1,
      "_comment_lookahead": "1 candle = 1 week",

      "feature_importance": {
        "trend": 0.50,
        "regime": 0.30,
        "support_resistance": 0.15,
        "btc_dominance": 0.05,
        "_comment": "1w focuses on trend and market regime"
      },

      "use_for": [
        "trend_confirmation",
        "regime_detection",
        "major_support_resistance",
        "long_term_bias"
      ],

      "min_data_points": 52,
      "_comment_data": "Minimum 52 candles (1 year) for training"
    }
  },

  "_signal_generation": {
    "description": "How to combine signals from multiple timeframes",

    "method": "weighted_voting",
    "_comment_method": "Aggregate predictions using timeframe weights",

    "alignment_bonus": 0.15,
    "_comment_alignment": "Add 15% to confidence if all 3 TFs agree on direction",

    "divergence_penalty": 0.10,
    "_comment_divergence": "Reduce 10% confidence if TFs disagree",

    "min_timeframes_agree": 2,
    "_comment_min_agree": "At least 2 out of 3 TFs must agree (2/3 majority)",

    "dominant_timeframe": "1d",
    "_comment_dominant": "1d is tiebreaker if 4h and 1w disagree"
  },

  "_ensemble_strategy": {
    "description": "How to use different timeframes together",

    "entry_rules": {
      "primary": "1d BUY signal with confidence > threshold",
      "confirmation_4h": "4h shows upward momentum (not contradicting)",
      "confirmation_1w": "1w in uptrend or neutral (not strong downtrend)",
      "_logic": "1d drives entry, 4h/1w provide confirmation"
    },

    "exit_rules": {
      "tp_hit": "Take profit reached on any timeframe",
      "sl_hit": "Stop loss hit on any timeframe",
      "signal_reversal": "1d flips to SELL with high confidence",
      "divergence": "Strong divergence: 4h/1d bearish while in long position"
    },

    "position_sizing": {
      "base": "Use crypto-specific base size",
      "alignment_multiplier": "1.2x if all 3 TFs aligned",
      "divergence_multiplier": "0.8x if TFs diverge"
    }
  },

  "_regime_detection": {
    "description": "Market regime identification using multi-TF analysis",

    "regimes": {
      "strong_uptrend": {
        "1w": "uptrend",
        "1d": "uptrend",
        "4h": "uptrend or neutral",
        "strategy": "Aggressive longs, wider TP"
      },
      "weak_uptrend": {
        "1w": "uptrend or neutral",
        "1d": "uptrend",
        "4h": "mixed",
        "strategy": "Normal longs, standard TP/SL"
      },
      "ranging": {
        "1w": "neutral",
        "1d": "mixed signals",
        "4h": "choppy",
        "strategy": "Reduce position size, tighter TP/SL"
      },
      "weak_downtrend": {
        "1w": "downtrend or neutral",
        "1d": "downtrend",
        "4h": "mixed",
        "strategy": "Cautious, tight SL"
      },
      "strong_downtrend": {
        "1w": "downtrend",
        "1d": "downtrend",
        "4h": "downtrend or neutral",
        "strategy": "Avoid trading or short only (if shorting enabled)"
      }
    }
  },

  "_dynamic_parameters": {
    "description": "Adjust parameters based on multi-TF context",

    "take_profit": {
      "strong_uptrend": "1.3x base TP (e.g., 5% → 6.5%)",
      "weak_uptrend": "1.0x base TP",
      "ranging": "0.7x base TP (take profits quickly)",
      "downtrend": "0.5x base TP (if trading at all)"
    },

    "stop_loss": {
      "high_volatility_4h": "1.2x base SL (give room)",
      "low_volatility_4h": "0.8x base SL (tighter)",
      "aligned_trend": "1.0x base SL",
      "diverging_trend": "0.8x base SL (protect capital)"
    },

    "confidence_threshold": {
      "all_aligned": "-5% (lower threshold, e.g., 50% → 45%)",
      "majority_aligned": "0% (no adjustment)",
      "diverging": "+10% (higher threshold, e.g., 50% → 55%)"
    }
  }
}
