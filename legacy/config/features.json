  "_feature_calculation_order": {
    "description": "Order in which to calculate features (dependencies)",
    "order": [
      "1. base_indicators",
      "2. temporal_features (depends on base)",
      "3. btc_influence (needs BTC base indicators)",
      "4. time_features (standalone)",
      "5. multi_tf_features (needs features from all TFs)",
      "6. regime_detection (needs base + multi_tf)",
      "7. volume_analysis (needs base + volume data)"
    ]
  },

  "_data_leakage_prevention": {
    "description": "CRITICAL: Prevent future data from leaking into features",
    "rules": [
      "1. All features use ONLY past data (t-1, t-2, ..., never t+1)",
      "2. Rolling windows use PAST N periods (not centered)",
      "3. Labels use FUTURE data (t+7 for 1d) - this is OK",
      "4. Lag features always lag >= 1 period",
      "5. Multi-TF alignment uses SYNCHRONIZED timestamps",
      "6. Validation: Check all feature logic for future peeking"
    ]
  }
